{{ printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
{{- /* Sitemap unifie a la racine : liste toutes les pages FR (a la racine) et EN (/en/).
       Les URLs fr sont servies depuis meilleur-transport.com/, les EN depuis meilleur-transport.com/en/.
       Un seul sitemap evite le probleme des sitemaps en sous-dossier qui listent des URLs au-dessus. */ -}}

{{- $allPages := slice -}}
{{- range hugo.Sites -}}
  {{- range .RegularPages -}}
    {{- if and (ne .Kind "taxonomy") (not .Params.private) (not .Params.noindex) -}}
      {{- $isTag := or (eq .Type "tags") (eq .Section "tags") -}}
      {{- if not $isTag -}}
        {{- $allPages = $allPages | append . -}}
      {{- end -}}
    {{- end -}}
  {{- end -}}
  {{- /* Home + listing + categories pour chaque site */ -}}
  {{- with .Home -}}{{- $allPages = $allPages | append . -}}{{- end -}}
  {{- range .Sections -}}
    {{- if ne .Section "tags" -}}
      {{- $allPages = $allPages | append . -}}
    {{- end -}}
  {{- end -}}
  {{- range (where .Pages "Kind" "term") -}}
    {{- $isTag := or (eq .Type "tags") (eq .Section "tags") -}}
    {{- if and (not $isTag) (not .Params.private) -}}
      {{- $allPages = $allPages | append . -}}
    {{- end -}}
  {{- end -}}
{{- end -}}

{{- range $allPages }}
  <url>
    <loc>{{ .Permalink }}</loc>
    <lastmod>{{ if not .Lastmod.IsZero }}{{ .Lastmod.Format "2006-01-02" }}{{ else }}{{ now.Format "2006-01-02" }}{{ end }}</lastmod>
    {{- $cf := "monthly" -}}
    {{- $pr := "0.5" -}}
    {{- if eq .Kind "home" }}{{ $cf = "weekly" }}{{ $pr = "1.0" }}{{ end -}}
    {{- if and (eq .Kind "section") (eq .Section "blog") }}{{ $cf = "daily" }}{{ $pr = "0.9" }}{{ end -}}
    {{- if and (eq .Kind "page") (eq .Section "blog") }}{{ $cf = "weekly" }}{{ $pr = "0.8" }}{{ end -}}
    {{- if eq .Section "categories" }}{{ $cf = "weekly" }}{{ $pr = "0.7" }}{{ end -}}
    <changefreq>{{ $cf }}</changefreq>
    <priority>{{ $pr }}</priority>
  </url>
{{- end }}
</urlset>
